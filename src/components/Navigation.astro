---
import ThemeToggle from './ThemeToggle.astro';
---

<nav
  class='sticky top-0 z-50 font-medium w-200 px-4 xl:px-0 mx-auto bg-white dark:bg-black transition-colors duration-300 border-0 shadow-none'
>
  <div class='flex justify-between items-center'>
    <ul
      class='flex justify-evenly gap-x-4 items-center sm:max-w-1/4 w-full text-gray-800 dark:text-white mx-auto py-4 w-fit'
    >
      <li>
        <a href='/' class='group transition duration-300'>
          Home
          <span
            class='block max-w-0 group-hover:max-w-full transition-all duration-500 h-0.5 bg-rose dark:bg-pink'
          ></span>
        </a>
      </li>
      <li>
        <a href='/about' class='group transition duration-300'>
          About
          <span
            class='block max-w-0 group-hover:max-w-full transition-all duration-500 h-0.5 bg-rose dark:bg-pink'
          ></span>
        </a>
      </li>
      <li>
        <a href='/contact' class='group transition duration-300'>
          Contact
          <span
            class='block max-w-0 group-hover:max-w-full transition-all duration-500 h-0.5 bg-rose dark:bg-pink'
          ></span>
        </a>
      </li>
    </ul>
    <div class='flex items-center'>
      <ThemeToggle />
    </div>
  </div>
</nav>
