---
import Placeholder from '../assets/placeholder.svg';
const personalWork = [
  {
    title: 'Project 1',
    description: 'Description 1',
    image: Placeholder,
  },
  {
    title: 'Project 2',
    description: 'Description 2',
    image: Placeholder,
  },
  {
    title: 'Project 3',
    description: 'Description 3',
    image: Placeholder,
  },
  {
    title: 'Project 4',
    description: 'Description 4',
    image: Placeholder,
  },
  {
    title: 'Project 5',
    description: 'Description 5',
    image: Placeholder,
  },
  {
    title: 'Project 6',
    description: 'Description 6',
    image: Placeholder,
  },
];
---

<div id='personal-work' class='h-[calc(100vh-58px)]'>
  <div class='container px-4 xl:px-0 mx-auto w-fit'>
    <section
      data-aos='fade-right'
      data-aos-duration='800'
      data-aos-anchor-placement='center-bottom'
      class='w-fit flex flex-col items-start justify-start mb-6'
    >
      <h1 class='text-4xl font-bold mb-2'>My Personal Work</h1>
      <h2 class='text-lg text-accent font-semibold'>Earth's essence</h2>
    </section>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 justify-items-center justify-content-center gap-10">
    {
      personalWork.map((project, index) => (
        <div
          data-aos='fade-right'
          data-aos-duration='800'
          data-aos-anchor-placement='bottom-bottom'
          data-aos-delay={index * 100}
        >
          <figure class='w-60 h-60 text-zinc-800 md:transition md:duration-300 md:ease-in-out md:hover:-translate-y-1'>
            <Placeholder />
            <figcaption class='text-center text-sm mt-1.5 text-accent font-semibold'>
              {project.title}
            </figcaption>
          </figure>
        </div>
      ))
    }
    </div>
  </div>
</div>
