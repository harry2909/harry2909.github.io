---
import '../styles/global.css';
import '@fontsource-variable/sora';
import 'aos/dist/aos.css';
import Navigation from '../components/Navigation.astro';
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='generator' content={Astro.generator} />
    <title>Ruby Preston - Portfolio</title>
  </head>
  <body
    class='bg-white dark:bg-black text-gray-800 dark:text-black antialiased min-h-screen w-full m-0 p-0 font-sora transition-colors duration-300 overflow-x-hidden'
  >
    <Navigation />
    <slot />
    <script>
      import AOS from 'aos';
      AOS.init();
    </script>
  </body>
</html>
