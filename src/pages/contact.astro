---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class='container px-4 xl:px-0 mx-auto'>
    <h1 class='text-4xl font-bold mb-2 text-gray-800 dark:text-white'>
      Contact
    </h1>
    <form action=''>
      <div class='flex flex-col gap-y-2'>
        <label for='name' class='text-sm text-gray-700 dark:text-white'
          >Name</label
        >
        <input
          type='text'
          id='name'
          name='name'
          class='border border-gray-300 dark:border-gray-600 rounded-md p-2 bg-white dark:bg-gray-800 text-gray-800 dark:text-black'
        />
      </div>
      <div class='flex flex-col gap-y-2'>
        <label for='email' class='text-sm text-gray-700 dark:text-white'
          >Email</label
        >
        <input
          type='email'
          id='email'
          name='email'
          class='border border-gray-300 dark:border-gray-600 rounded-md p-2 bg-white dark:bg-gray-800 text-gray-800 dark:text-black'
        />
      </div>
      <div class='flex flex-col gap-y-2'>
        <label for='message' class='text-sm text-gray-700 dark:text-white'
          >Message</label
        >
        <textarea
          id='message'
          name='message'
          class='border border-gray-300 dark:border-gray-600 rounded-md p-2 bg-white dark:bg-gray-800 text-gray-800 dark:text-black'
        ></textarea>
      </div>
      <button
        type='submit'
        class='bg-rose dark:bg-pink text-white rounded-md p-2 hover:bg-rose dark:hover:bg-pink transition-colors'
        >Send</button
      >
    </form>
  </div>
</Layout>
